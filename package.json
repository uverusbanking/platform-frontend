{
  "name": "company-admin-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:control & pnpm run dev:dashboard & pnpm run dev:personal-web & pnpm run dev:corporate-web",
    "dev:control": "next dev control -p 3000",
    "dev:dashboard": "next dev dashboard -p 3001",
    "dev:personal-web": "cd personal-web && npx vite --port 3002",
    "dev:corporate-web": "next dev corporate-web -p 3003",
    "build": "pnpm run build:control && pnpm run build:dashboard && pnpm run build:personal-web && pnpm run build:corporate-web",
    "build:control": "next build control",
    "build:dashboard": "next build dashboard",
    "build:personal-web": "cd personal-web && npx vite build",
    "build:corporate-web": "next build corporate-web",
    "start": "pnpm run start:control & pnpm run start:dashboard & pnpm run start:personal-web & pnpm run start:corporate-web",
    "start:control": "next start control -p 3000",
    "start:dashboard": "next start dashboard -p 3001",
    "start:personal-web": "cd personal-web && npx vite preview --port 3002",
    "start:corporate-web": "next start corporate-web -p 3003",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
