# ─── API CONNECTIVITY ──────────────────────────────────────────────────
# Unified backend API URL (used by most apps)
VITE_API_URL=http://localhost:3000
# Used specifically by personal-web (standardized to base_url)
VITE_API_BASE_URL=http://localhost:3000
VITE_API_VERSION=v1

# ─── SESSION & SECURITY ───────────────────────────────────────────────
# Inactivity duration before warning (ms) - standard naming
VITE_INACTIVITY_LIMIT=300000
# Equivalent used by personal-web (standardized)
VITE_INACTIVITY_WARNING_MS=300000

# Warning duration modal stays visible before auto-logout (ms)
VITE_WARNING_DURATION=30000
# Equivalent used by personal-web
VITE_WARNING_TIMEOUT_MS=30000

# Personal-web specific timeouts (ms)
VITE_HIDDEN_TAB_TIMEOUT_MS=300000
VITE_TAB_CLOSE_TIMEOUT_MS=300000

# ─── BRANDING & CUSTOMIZATION ─────────────────────────────────────────
VITE_BRAND_CONFIG_URL=

# ─── THIRD-PARTY INTEGRATIONS ───────────────────────────────────────
# Required for corporate-web
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
